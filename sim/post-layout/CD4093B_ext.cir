Rvss vss 0 1u ; laczy vss do masy
Rc C A 1u ; laczy zrodla napieciowe A i B do reszty wyprowadzen ukladu
Rd D B 1u
Re E A 1u
Rf F B 1u
Rg G A 1u
Rh H B 1u
Cload_J J 0 25p
Cload_K K 0 25p
Cload_L L 0 25p
Cload_M M 0 25p

.param VDD=1.8V
.param Bin=1.8V

;.step param temp list -30 27 120
;.step param VDD list 1.72 1.8 1.98


Vdd vdd 0 {VDD}
Vb B 0 {Bin}

.param freq=30MEG
.param Tperiod=1/{freq}
.param Ton=0.5*{Tperiod}

Ra A ra 50; rezystancja szeregowa zrodla
VaCLOCK ra 0 PULSE(0 1.8 0 .1n .1n {Ton} {Tperiod}) ; przebieg prostokatny
; do badania do zbadania przebiegów wyjsciowych oraz maksymalnej czestotliwosci ukladu
;VaSIN ra 0 SINE(0.9V 0.9V {freq} 0 0 -90) ; przebieg sinusoidalny
; do zaobserwowania oraz wykreslenia histerezy

.tran 0 200n 0 100p
.op ;
.end
